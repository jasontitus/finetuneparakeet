# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data (large, reproducible from scripts)
data/cv25_lt/
data/manifests/audio/
data/lm/*.arpa
data/lm/*.pkl
data/lm/*.txt

# Manifests contain machine-specific absolute paths (e.g. /Users/<user>/...).
# Rebuilt on each machine by scripts/03_prepare_manifests.py, so no need to track.
data/manifests/

# Claude Code local settings
.claude/

# Training artifacts (large, re-generated per run)
checkpoints/
lightning_logs/
*.nemo
*.ckpt

# Eval outputs (large, re-generated)
results/*/per_clip.jsonl
# Keep summary.json and text reports for history
!results/*/summary.json

# Logs
*.log
nohup.out
/tmp/

# KenLM build (cloned + compiled by 12_build_lm_from_hf.sh)
tools/

# LM build temps
data/lm/hf-corpora/
data/lm/tmp/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo
